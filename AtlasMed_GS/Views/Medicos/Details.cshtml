@model AtlasMed_GS.Models.Medico

@{
    ViewData["Title"] = "Detalhes do Médico";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AtlasMed - Sua plataforma de gerenciamento de registros médicos</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #3498db;
            color: #333;
        }

        header {
            color: #fff;
            text-align: center;
        }

        section {
            max-width: 800px;
            margin: 20px auto;
            padding: 20px;
            background-color: #fff;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
        }

        div {
            background-color: #fff;
        }

    </style>
</head>
<body>

    <h1>Detalhes</h1>

    <div>
        <hr />
        <dl class="row">
            <dt class = "col-sm-2">
                Nome:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Nome)
            </dd>
            <dt class = "col-sm-2">
                CPF:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Cpf)
            </dd>
            <dt class = "col-sm-2">
                CRM:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Crm)
            </dd>
            <dt class = "col-sm-2">
                Especialidade:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Especialidade)
            </dd>
            <dt class = "col-sm-2">
                Hospital:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Hospital.Nome)
            </dd>
        </dl>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model?.IdMedico">Editar</a> |
        <a asp-action="Index">Voltar</a>
    </div>

</body>
</html>
