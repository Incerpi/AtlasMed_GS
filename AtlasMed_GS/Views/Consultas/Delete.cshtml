@model AtlasMed_GS.Models.Consulta

@{
    ViewData["Title"] = "Excluir Consulta";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AtlasMed - Sua plataforma de gerenciamento de registros médicos</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #3498db;
            color: #333;
        }

        header {
            color: #fff;
            text-align: center;
        }

        section {
            max-width: 800px;
            margin: 20px auto;
            padding: 20px;
            background-color: #fff;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
        }

        div {
            background-color: #fff;
        }

    </style>
    <script>
        function confirmarExclusao() {
            var confirmacao = confirm("Tem certeza que deseja excluir esta consulta? Esta ação é irreversível!");

            if (confirmacao) {
                alert("Consulta excluída com sucesso!");
                return true;
            } else {
                return false;
            }
        }
    </script>
</head>
<body>

    <h2>Excluir</h2>

    <div>
        <h4>Consulta</h4>
        <hr />
        <dl class="row">
            <dt class = "col-sm-2">
                Paciente:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Paciente.Nome)
            </dd>
            <dt class = "col-sm-2">
                Médico:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Medico.Nome)
            </dd>
            <dt class = "col-sm-2">
                Prontuário:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Prontuario.Descricao)
            </dd>
            <dt class = "col-sm-2">
                Hospital:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Hospital.Nome)
            </dd>
            <dt class = "col-sm-2">
                Horário:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Horario)
            </dd>
        </dl>
    
        <form asp-action="Delete" onsubmit="return confirmarExclusao()">
            <input type="hidden" asp-for="IdConsulta" />
            <input type="submit" value="Excluir" class="btn btn-danger" /> |
            <a asp-action="Index">Voltar</a>
        </form>
    </div>

</body>
</html> 
