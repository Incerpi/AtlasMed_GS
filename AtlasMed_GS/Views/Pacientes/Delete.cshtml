@model AtlasMed_GS.Models.Paciente

@{
    ViewData["Title"] = "Excluir Paciente";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AtlasMed - Sua plataforma de gerenciamento de registros médicos</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #3498db;
            color: #333;
        }

        header {
            color: #fff;
            text-align: center;
        }

        section {
            max-width: 800px;
            margin: 20px auto;
            padding: 20px;
            background-color: #fff;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
        }

        div {
            background-color: #fff;
        }

    </style>
    <script>
        function confirmarExclusao() {
            var confirmacao = confirm("Tem certeza que deseja excluir este paciente? Esta ação é irreversível!");

            if (confirmacao) {
                alert("Paciente excluído com sucesso!");
                return true;
            } else {
                return false;
            }
        }
    </script>
</head>
<body>

    <h2>Excluir</h2>

    <div>
        <hr />
        <dl class="row">
            <dt class = "col-sm-2">
                Nome:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Nome)
            </dd>
            <dt class = "col-sm-2">
                CPF:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Cpf)
            </dd>
            <dt class = "col-sm-2">
                Data de Nascimento:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.DataNascimento)
            </dd>
            <dt class = "col-sm-2">
                Email:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Email)
            </dd>
            <dt class = "col-sm-2">
                Telefone:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Telefone)
            </dd>
            <dt class = "col-sm-2">
                Rua:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Rua)
            </dd>
            <dt class = "col-sm-2">
                Número:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Numero)
            </dd>
            <dt class = "col-sm-2">
                Bairro:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Bairro)
            </dd>
            <dt class = "col-sm-2">
                Cidade:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Cidade)
            </dd>
            <dt class = "col-sm-2">
                Estado:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Estado)
            </dd>
            <dt class = "col-sm-2">
                CEP:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Cep)
            </dd>
        </dl>
    
        <form asp-action="Delete" onsubmit="return confirmarExclusao()">
            <input type="hidden" asp-for="IdPaciente" />
            <input type="submit" value="Excluir" class="btn btn-danger" /> |
            <a asp-action="Index">Voltar</a>
        </form>
    </div>

</body>
</html>
