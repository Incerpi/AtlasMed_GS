@model AtlasMed_GS.Models.Hospital

@{
    ViewData["Title"] = "Excluir Hospital";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AtlasMed - Sua plataforma de gerenciamento de registros médicos</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #3498db;
            color: #333;
        }

        header {
            color: #fff;
            text-align: center;
        }

        section {
            max-width: 800px;
            margin: 20px auto;
            padding: 20px;
            background-color: #fff;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
        }

        div {
            background-color: #fff;
        }

    </style>
</head>
<body>

    <h2>Excluir</h2>

    <h3>Tem certeza? Esta ação é irreversível!</h3>
    <div>
        <hr />
        <dl class="row">
            <dt class = "col-sm-2">
                Nome:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Nome)
            </dd>
            <dt class = "col-sm-2">
                Telefone:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Telefone)
            </dd>
            <dt class = "col-sm-2">
                Rua:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Rua)
            </dd>
            <dt class = "col-sm-2">
                Número:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Numero)
            </dd>
            <dt class = "col-sm-2">
                Bairro:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Bairro)
            </dd>
            <dt class = "col-sm-2">
                Cidade:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Cidade)
            </dd>
            <dt class = "col-sm-2">
                Estado:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Estado)
            </dd>
            <dt class = "col-sm-2">
                CEP:
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Cep)
            </dd>
        </dl>
    
        <form asp-action="Delete">
            <input type="hidden" asp-for="IdHospital" />
            <input type="submit" value="Excluir" class="btn btn-danger" /> |
            <a asp-action="Index">Voltar</a>
        </form>
    </div>

</body>
</html>

